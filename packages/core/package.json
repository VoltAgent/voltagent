    "type-fest": "^4.41.0",
    "uuid": "^9.0.1",
    "zod-from-json-schema": "^0.5.0"
  },
  "devDependencies": {
    "@ai-sdk/provider-utils": "^5.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ai": "^7.0.0",
    "msw": "^2.11.5",
    "zod": "^4.1.11"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "peerDependencies": {
    "@ai-sdk/provider-utils": "^5.0.0",
    "@voltagent/logger": "3.0.0-next.0",
    "ai": "^7.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@voltagent/logger": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VoltAgent/voltagent.git",
    "directory": "packages/core"
  },
  "scripts": {
    "attw": "attw --pack",
    "build": "tsup",
    "dev": "tsup --watch",
    "generate:model-registry": "node scripts/generate-model-provider-registry.js",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "prebuild": "node ../../scripts/sync-docs-mcp.js",
    "prepack": "node ../../scripts/sync-docs-mcp.js",
    "publint": "publint --strict",
    "sync-docs": "node ../../scripts/sync-docs-mcp.js",
    "test": "vitest --reporter=hanging-process --reporter=default --typecheck",
    "test:coverage": "vitest run --coverage --typecheck",
    "test:single": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit"
  },
  "types": "dist/index.d.ts",
  "type": "module"
}
