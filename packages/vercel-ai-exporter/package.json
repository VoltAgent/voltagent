{
  "name": "@voltagent/vercel-ai-exporter",
  "description": "OpenTelemetry exporter for VoltAgent observability with Vercel AI SDK",
  "version": "3.0.0-next.0",
  "author": "VoltAgent Team",
  "dependencies": {
    "@opentelemetry/core": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@voltagent/sdk": "^3.0.0-next.0"
  },
  "devDependencies": {
    "@voltagent/core": "^3.0.0-next.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "llm",
    "observability",
    "opentelemetry",
    "vercel-ai",
    "voltagent"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "peerDependencies": {
    "@voltagent/core": "^3.0.0-next.0",
    "ai": "^7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voltagentai/voltagent.git",
    "directory": "packages/vercel-ai-exporter"
  },
  "scripts": {
    "attw": "attw --pack",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "publint": "publint --strict",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "types": "dist/index.d.ts",
  "type": "module"
}
